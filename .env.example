# Honeypot API Configuration Template
# Copy this file to .env and fill in your values

# --- API Security ---
# Secret key required in the x-api-key header for all incoming requests
HONEYPOT_API_KEY=your_secure_api_key_here

# --- LLM Configuration ---
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Recommended Models: anthropic/claude-3.5-sonnet, openai/gpt-4o, or google/gemini-1.5-pro
LLM_MODEL=anthropic/claude-3.5-sonnet

HTTP_REFERER=https://your-domain.com
APP_NAME=ScamHoneypot

# --- Webhook Integration ---
# URL to receive POST requests when intelligence is extracted
CALLBACK_URL=https://api.yourcompany.com/webhooks/scam-intel

# --- Server Configuration ---
PORT=8000
DEBUG=0
MOCK_MODE=0
